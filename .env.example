# ─────────────────────────────────────────────
# Local API server (server/index.js)
# ─────────────────────────────────────────────
PORT=4000

# Expo client API endpoint (src/config/api.ts)
# Use http://localhost:4000 for web/emulator.
# For a physical device on the same network use your LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.20:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# ─────────────────────────────────────────────
# Supabase (required for auth + database)
# https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Used by server/index.js for server-side Supabase operations (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# AI providers for the health companion
# (server/index.js falls back to deterministic
#  replies if all keys are left blank)
# ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

GEMINI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
